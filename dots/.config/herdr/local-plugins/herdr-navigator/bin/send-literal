#!/usr/bin/env bash
# Send literal ctrl-h/j/k/l to the active Herdr pane.
# Intended as prefix+ctrl-h/j/k/l escape hatches for TUIs like k9s.

set -euo pipefail

dir="${1:?usage: send-literal <left|down|up|right>}"
herdr="${HERDR_BIN_PATH:-herdr}"
pane="${HERDR_ACTIVE_PANE_ID:-${HERDR_PANE_ID:-}}"

case "$dir" in
  left)  key="ctrl+h" ;;
  down)  key="ctrl+j" ;;
  up)    key="ctrl+k" ;;
  right) key="ctrl+l" ;;
  *) echo "send-literal: unknown direction: $dir" >&2; exit 2 ;;
esac

if [ -z "$pane" ]; then
  echo "send-literal: HERDR_ACTIVE_PANE_ID/HERDR_PANE_ID is not set" >&2
  exit 1
fi

exec "$herdr" pane send-keys "$pane" "$key"
